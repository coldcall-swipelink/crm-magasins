generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
}

model Store {
  id               String   @id @default(cuid())
  brandId          String?
  brand            Brand?   @relation(fields: [brandId], references: [id])
  name             String
  normalizedName   String
  city             String   @default("")
  postalCode       String   @default("")
  department       String   @default("")
  address          String   @default("")
  phone            String   @default("")
  email            String   @default("")
  siret            String   @default("")
  externalId       String   @default("")
  deduplicationKey String   @unique
  // Coordonnées GPS issues du géocodage de l'adresse (API BAN data.gouv).
  // Mises en cache pour éviter de re-géocoder à chaque ouverture de la carte.
  latitude         Float?
  longitude        Float?
  geocodedAt       DateTime?
  geocodeQuery     String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deal             Deal?
  jobOffers        JobOffer[]
  importRows       ImportRow[]
}

model Collaborator {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]
}

// Utilisateur de l'application (identité choisie à la première connexion,
// stockée côté navigateur). Complémentaire de Collaborator : sert à savoir
// qui est connecté, qui suit un deal, à qui une action est assignée et qui
// rédige une note.
model User {
  id              String   @id @default(cuid())
  name            String   @unique
  color           String   @default("#6366f1")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  assignedDeals   Deal[]
  assignedActions Action[]
  authoredNotes   Note[]
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String   @unique
  position  Int      @default(0)
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  columns   PipelineColumn[]
  deals     Deal[]
}

model PipelineColumn {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  title      String
  position   Int
  color      String   @default("#6366f1")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  deals      Deal[]
}

model Deal {
  id                        String   @id @default(cuid())
  pipelineId                String
  pipeline                  Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  storeId                   String   @unique
  store                     Store    @relation(fields: [storeId], references: [id])
  columnId                  String
  column                    PipelineColumn @relation(fields: [columnId], references: [id])
  previousColumnId          String?
  // Regroupement d'affaires : un « gros » deal peut en absorber d'autres
  // (autres magasins d'un même groupe). Un sous-deal disparaît du pipeline et
  // reste accessible via son parent ou la recherche. Limité à un seul niveau.
  parentDealId              String?
  parentDeal                Deal?    @relation("DealHierarchy", fields: [parentDealId], references: [id], onDelete: SetNull)
  childDeals                Deal[]   @relation("DealHierarchy")
  priority                  String   @default("normale")
  // Tag commercial : true = Prospection de Valeur (PV), false = Prospection
  // Classique (PC). Affiché sous forme de puce à cocher sur chaque affaire.
  isPV                      Boolean  @default(true)
  // Mode de paiement choisi pour les affaires en étape « SMARTLINKÉ » :
  // "stripe" (par défaut) ou "virement". Affiché sous forme d'interrupteur sur
  // la fiche affaire uniquement quand l'affaire est dans cette étape.
  paymentMode               String   @default("stripe")
  position                  Int      @default(0)
  isNewFromLastImport       Boolean  @default(false)
  hasNewOfferFromLastImport Boolean  @default(false)
  isPresentInLastImport     Boolean  @default(true)
  movedToCallAt             DateTime?
  lastImportAt              DateTime?
  directeur                 String   @default("")
  contactCalling            String   @default("")
  dealEmail                 String   @default("")
  contactCivilite           String   @default("Monsieur")
  contactLastName           String   @default("")
  dealValue                 Float?
  demoDate                  DateTime?
  candidateCallDate         DateTime?
  // Date de closing : renseignée à l'entrée dans l'étape « SMARTLINKÉ »
  // (demandée au drag & drop) et modifiable depuis la fiche affaire.
  closingDate               DateTime?
  googleEventId             String?
  googleMeetUrl             String?
  // Id de l'Organization créée dans la base produit Supabase quand l'affaire
  // passe en « Démo prévue » (garantit l'idempotence du provisioning).
  supabaseOrganizationId    String?
  // True quand l'utilisateur a géré manuellement les organisations rattachées :
  // on n'exécute alors plus le rattachement automatique par nom.
  supabaseOrgManual         Boolean  @default(false)
  collaboratorId            String?
  collaborator              Collaborator? @relation(fields: [collaboratorId], references: [id])
  assignedUserId            String?
  assignedUser              User?    @relation(fields: [assignedUserId], references: [id])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  jobOffers                 JobOffer[]
  actions                   Action[]
  notes                     Note[]
  importRows                ImportRow[]
  emailLogs                 EmailLog[]
  candidateCalls            CandidateCall[]
  organizationLinks         DealOrganization[]
}

model JobOffer {
  id              String   @id @default(cuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id])
  importBatchId   String
  importBatch     ImportBatch @relation(fields: [importBatchId], references: [id])
  externalOfferId String   @default("")
  title           String   @default("")
  jobTitle        String   @default("")
  contractType    String   @default("")
  salary          String   @default("")
  source          String   @default("")
  url             String   @default("")
  publishedAt     String   @default("")
  fingerprint     String   @unique
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ImportBatch {
  id                String   @id @default(cuid())
  fileName          String
  importedAt        DateTime @default(now())
  totalRows         Int      @default(0)
  createdDeals      Int      @default(0)
  updatedDeals      Int      @default(0)
  newOffers         Int      @default(0)
  movedToCall       Int      @default(0)
  errorCount        Int      @default(0)
  createdAt         DateTime @default(now())
  importRows        ImportRow[]
  jobOffers         JobOffer[]
}

model ImportRow {
  id            String   @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber     Int
  rawData       Json
  status        String   @default("ok")
  errorMessage  String   @default("")
  storeId       String?
  store         Store?   @relation(fields: [storeId], references: [id])
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id])
  createdAt     DateTime @default(now())
}

model Action {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String
  type        String    @default("Appeler")
  dueDate     DateTime  @db.Timestamptz
  dueTime     String    @default("")
  status      String    @default("todo")
  priority    String    @default("normale")
  note        String    @default("")
  completedAt DateTime?
  assignedUserId String?
  assignedUser   User?   @relation(fields: [assignedUserId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Note {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  content    String
  authorId   String?
  author     User?    @relation(fields: [authorId], references: [id])
  authorName String   @default("")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model EmailTemplate {
  id        String     @id @default(cuid())
  name      String
  subject   String     @default("")
  body      String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  emailLogs EmailLog[]
}

model EmailLog {
  id         String         @id @default(cuid())
  dealId     String
  deal       Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  to         String
  subject    String
  body       String
  status     String         @default("sent")
  resendId   String?
  openedAt   DateTime?
  sentAt     DateTime       @default(now())
  createdAt  DateTime       @default(now())
}

// Suivi CRM des appels aux candidats affichés dans l'onglet « Recrutement ».
// candidateId = id du Candidate dans la base produit Supabase. La présence
// d'une ligne signifie « candidat appelé » pour ce deal (case cochée).
model CandidateCall {
  id          String   @id @default(cuid())
  dealId      String
  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  candidateId String
  calledAt    DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([dealId, candidateId])
}

// Organisations produit (Supabase) rattachées à un deal. Permet d'en lier
// plusieurs (en plus de Deal.supabaseOrganizationId issu du provisioning) et
// de les renseigner manuellement quand l'auto-rattachement par nom échoue.
model DealOrganization {
  id             String   @id @default(cuid())
  dealId         String
  deal           Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  organizationId String
  createdAt      DateTime @default(now())

  @@unique([dealId, organizationId])
}

// Réglages globaux de l'application (clé/valeur). Ex. « emailSignature » :
// signature HTML ajoutée automatiquement à tous les emails envoyés du CRM.
model AppSetting {
  key       String   @id
  value     String   @default("")
  updatedAt DateTime @updatedAt
}
