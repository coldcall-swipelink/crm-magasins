generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]
}

model Store {
  id               String   @id @default(cuid())
  brandId          String?
  brand            Brand?   @relation(fields: [brandId], references: [id])
  name             String
  normalizedName   String
  city             String   @default("")
  postalCode       String   @default("")
  department       String   @default("")
  address          String   @default("")
  phone            String   @default("")
  email            String   @default("")
  siret            String   @default("")
  externalId       String   @default("")
  deduplicationKey String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  deal             Deal?
  jobOffers        JobOffer[]
  importRows       ImportRow[]
}

model Collaborator {
  id        String   @id @default(cuid())
  name      String
  email     String   @default("")
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deals     Deal[]
}

model Pipeline {
  id        String   @id @default(cuid())
  name      String   @unique
  position  Int      @default(0)
  color     String   @default("#6366f1")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  columns   PipelineColumn[]
  deals     Deal[]
}

model PipelineColumn {
  id         String   @id @default(cuid())
  pipelineId String
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  title      String
  position   Int
  color      String   @default("#6366f1")
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  
  deals      Deal[]
}

model Deal {
  id                        String   @id @default(cuid())
  pipelineId                String
  pipeline                  Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  storeId                   String   @unique
  store                     Store    @relation(fields: [storeId], references: [id])
  columnId                  String
  column                    PipelineColumn @relation(fields: [columnId], references: [id])
  previousColumnId          String?
  priority                  String   @default("normale")
  position                  Int      @default(0)
  isNewFromLastImport       Boolean  @default(false)
  hasNewOfferFromLastImport Boolean  @default(false)
  isPresentInLastImport     Boolean  @default(true)
  movedToCallAt             DateTime?
  lastImportAt              DateTime?
  directeur                 String   @default("")
  contactCalling            String   @default("")
  dealEmail                 String   @default("")
  contactCivilite           String   @default("Monsieur")
  contactLastName           String   @default("")
  dealValue                 Float?
  demoDate                  DateTime?
  collaboratorId            String?
  collaborator              Collaborator? @relation(fields: [collaboratorId], references: [id])
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
  jobOffers                 JobOffer[]
  actions                   Action[]
  notes                     Note[]
  importRows                ImportRow[]
  emailLogs                 EmailLog[]
}

model JobOffer {
  id              String   @id @default(cuid())
  dealId          String
  deal            Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  storeId         String
  store           Store    @relation(fields: [storeId], references: [id])
  importBatchId   String
  importBatch     ImportBatch @relation(fields: [importBatchId], references: [id])
  externalOfferId String   @default("")
  title           String   @default("")
  jobTitle        String   @default("")
  contractType    String   @default("")
  salary          String   @default("")
  source          String   @default("")
  url             String   @default("")
  publishedAt     String   @default("")
  fingerprint     String   @unique
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  status          String   @default("active")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ImportBatch {
  id                String   @id @default(cuid())
  fileName          String
  importedAt        DateTime @default(now())
  totalRows         Int      @default(0)
  createdDeals      Int      @default(0)
  updatedDeals      Int      @default(0)
  newOffers         Int      @default(0)
  movedToCall       Int      @default(0)
  disappearedOffers Int      @default(0)
  errorCount        Int      @default(0)
  createdAt         DateTime @default(now())
  importRows        ImportRow[]
  jobOffers         JobOffer[]
}

model ImportRow {
  id            String   @id @default(cuid())
  importBatchId String
  importBatch   ImportBatch @relation(fields: [importBatchId], references: [id], onDelete: Cascade)
  rowNumber     Int
  rawData       Json
  status        String   @default("ok")
  errorMessage  String   @default("")
  storeId       String?
  store         Store?   @relation(fields: [storeId], references: [id])
  dealId        String?
  deal          Deal?    @relation(fields: [dealId], references: [id])
  createdAt     DateTime @default(now())
}

model Action {
  id          String    @id @default(cuid())
  dealId      String
  deal        Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  title       String
  type        String    @default("Appeler")
  dueDate     DateTime
  dueTime     String    @default("")
  status      String    @default("todo")
  priority    String    @default("normale")
  note        String    @default("")
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Note {
  id        String   @id @default(cuid())
  dealId    String
  deal      Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmailTemplate {
  id        String     @id @default(cuid())
  name      String
  subject   String     @default("")
  body      String     @default("")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  emailLogs EmailLog[]
}

model EmailLog {
  id         String         @id @default(cuid())
  dealId     String
  deal       Deal           @relation(fields: [dealId], references: [id], onDelete: Cascade)
  templateId String?
  template   EmailTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  to         String
  subject    String
  body       String
  status     String         @default("sent")
  resendId   String?
  openedAt   DateTime?
  sentAt     DateTime       @default(now())
  createdAt  DateTime       @default(now())
}
