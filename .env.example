# ─── Base de données ──────────────────────────────────────────────────────────
# Option A : Supabase (recommandé)
# Récupérez l'URL dans Supabase → Settings → Database → Connection string (mode Transaction)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Option B : PostgreSQL local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_magasins"

# Option C : Supabase avec pooler (production)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="changez-moi-en-production-avec-openssl-rand-base64-32"
