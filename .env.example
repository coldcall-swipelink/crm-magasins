# ─── Base de données ──────────────────────────────────────────────────────────
# Option A : Supabase (recommandé)
# Récupérez l'URL dans Supabase → Settings → Database → Connection string (mode Transaction)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Option B : PostgreSQL local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_magasins"

# Option C : Supabase avec pooler (production)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="changez-moi-en-production-avec-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Bypass de l'écran d'identité (UserGate) — UNIQUEMENT pour les tests/preview.
# À "true", l'app s'ouvre sans demander de nom. NE PAS activer en production.
# (Variable NEXT_PUBLIC_*, inlinée au build → redéployer après changement.)
# NEXT_PUBLIC_BYPASS_USER_GATE="true"

# ─── Emails (Resend) ─────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxxxxxxxxxxxxxxxxxxxxxxx"
SMTP_FROM="Swipelink <contact@swipelink.fr>"
#
# Webhook Resend (POST /api/webhooks/resend) : enregistre dans le deal tout
# email parti par Resend (depuis le CRM OU depuis une automatisation N8N), en
# retrouvant l'affaire via son email de contact. À configurer dans Resend →
# Webhooks, en activant les events : email.sent, email.delivered, email.opened.

# ─── Google Calendar + Meet (étape « Démo prévue ») ──────────────────────────
# Quand une affaire passe en « Démo prévue », l'app crée un événement Google
# Calendar avec un Google Meet « Ouvert à tous » et invite le contact de
# l'affaire + bilal@swipelink.fr.
#
# Mise en place (OAuth2, à faire une seule fois) :
#   1. Google Cloud Console → créez un projet, activez « Google Calendar API »
#      ET « Google Meet API ».
#   2. Créez un identifiant OAuth 2.0 de type « Application de bureau ».
#   3. Générez un refresh token avec les scopes :
#        https://www.googleapis.com/auth/calendar.events
#        https://www.googleapis.com/auth/meetings.space.created
#      (ex. via https://developers.google.com/oauthplayground en réglant vos
#       propres client_id/secret dans les paramètres ⚙, ou via un script local).
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REFRESH_TOKEN=""

# Optionnel :
# GOOGLE_CALENDAR_ID="primary"              # agenda où créer l'événement
# GOOGLE_MEET_GUEST_EMAIL="bilal@swipelink.fr"  # invité systématique
# GOOGLE_MEET_DURATION_MIN="30"             # durée de l'événement en minutes
# GOOGLE_MEET_TIMEZONE="Europe/Paris"       # fuseau horaire de l'événement

# ─── Base produit Supabase (étape « Démo prévue ») ───────────────────────────
# Quand une affaire passe en « Démo prévue », en plus de l'invitation Google
# Meet, l'app crée dans la base PRODUIT (projet Supabase distinct du CRM) :
#   - une Organization (« Enseigne — Ville », avec logo selon l'enseigne)
#   - un Organization_to_plan (plan « One shot »)
#   - un Recruiter (admin, rattaché à un user fixe)
# Utiliser l'URL + la clé service_role (ou « secret ») du projet voulu.
# Si ces variables ne sont pas définies, l'étape est ignorée silencieusement.
SUPABASE_PRODUCT_URL=""                      # ex : https://xxxxxxxx.supabase.co
SUPABASE_PRODUCT_SERVICE_ROLE_KEY=""         # clé service_role / secret

# Optionnel (sinon valeurs par défaut dans le code) :
# SUPABASE_PRODUCT_PLAN_ID="38fb7e63-922e-45d9-9c35-a614edf7cc93"   # plan One shot
# SUPABASE_PRODUCT_RECRUITER_USER_ID="0c72c8d6-98a1-4aa5-8e91-91a70277bcaa"
# SUPABASE_PRODUCT_SMARTLINK_CREDITS="0"
