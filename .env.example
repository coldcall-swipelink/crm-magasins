# ─── Base de données ──────────────────────────────────────────────────────────
# Option A : Supabase (recommandé)
# Récupérez l'URL dans Supabase → Settings → Database → Connection string (mode Transaction)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Option B : PostgreSQL local
# DATABASE_URL="postgresql://postgres:password@localhost:5432/crm_magasins"

# Option C : Supabase avec pooler (production)
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-eu-west-3.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── Environnement de DÉVELOPPEMENT ──────────────────────────────────────────
# Pour travailler en local sans toucher à la base de production, créez une
# branche de base de données dédiée au dev (recommandé : "branching" Neon) et
# placez sa connection string dans un fichier .env.development.local :
#
#   DATABASE_URL="postgresql://...VOTRE_BRANCHE_DEV..."
#
# .env.development.local est ignoré par git ET chargé automatiquement par
# `npm run dev` (il a priorité sur .env). La prod continue d'utiliser .env.

# ─── Webhooks n8n ────────────────────────────────────────────────────────────
# Déclenchés lorsqu'une affaire passe dans certaines colonnes du pipeline.
# Laisser vide pour désactiver l'envoi (aucune erreur, simplement ignoré).
N8N_WEBHOOK_DEMO_FAITE=""
N8N_WEBHOOK_RELANCE_1=""

# ─── Emails (Resend) ─────────────────────────────────────────────────────────
# Laisser vide pour désactiver l'envoi d'emails (l'API renverra une erreur 503
# explicite au lieu de planter).
RESEND_API_KEY=""
SMTP_FROM="CRM Magasins <no-reply@votre-domaine.fr>"

# ─── Next.js ─────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="changez-moi-en-production-avec-openssl-rand-base64-32"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
